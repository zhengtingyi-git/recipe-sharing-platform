<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ChineseRecipeCommentDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.ChineseRecipeCommentEntity" id="chinese_recipe_commentMap">
        <result property="recipeId" column="recipe_id"/>
        <result property="userId" column="user_id"/>
        <result property="nickname" column="nickname"/>
        <result property="content" column="content"/>
        <result property="reply" column="reply"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.ChineseRecipeCommentVO" >
		SELECT * FROM recipe_comment  chinese_recipe_comment         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.ChineseRecipeCommentVO" >
		SELECT  chinese_recipe_comment.* FROM recipe_comment  chinese_recipe_comment 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.ChineseRecipeCommentView" >

		SELECT  chinese_recipe_comment.* FROM recipe_comment  chinese_recipe_comment 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.ChineseRecipeCommentView" >
		SELECT * FROM recipe_comment  chinese_recipe_comment <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

</mapper>

